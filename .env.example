# ═══════════════════════════════════════════
# FuviAI Marketing Agent — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git!
# ═══════════════════════════════════════════

# ═══════════════════════════════
# CORE — BẮT BUỘC
# ═══════════════════════════════
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ═══════════════════════════════
# DATABASE
# ═══════════════════════════════
DATABASE_URL=postgresql://fuviai:password@localhost:5432/marketing_agent
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════
# VECTOR DB
# ═══════════════════════════════
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=fuviai_knowledge

# ═══════════════════════════════
# SOCIAL PLATFORMS — Thêm dần theo phase
# ═══════════════════════════════
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_AD_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_APP_ID=
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_ACCESS_TOKEN=
SHOPEE_SHOP_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Google Custom Search (optional — fallback DuckDuckGo nếu để trống)
# Tạo tại: console.cloud.google.com + programmablesearchengine.google.com
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ═══════════════════════════════
# EMAIL (SendGrid)
# ═══════════════════════════════
# Đăng ký tại sendgrid.com — Free tier: 100 emails/ngày
# Phải verify domain sender trước khi gửi
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@fuviai.com
SENDGRID_FROM_NAME=FuviAI Marketing

# ═══════════════════════════════
# MONITORING
# ═══════════════════════════════
# Sentry error tracking — lấy DSN tại sentry.io
# Để trống = tắt Sentry (dev mode)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ═══════════════════════════════
# APP
# ═══════════════════════════════
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,https://marketing.fuviai.com
SECRET_KEY=your-secret-key-change-in-production
