{
  "platform": "facebook",
  "csv_content": "ad_name,impressions,clicks,spend,conversions\nAd A - Awareness,50000,900,5000000,45\nAd B - Retarget,20000,600,3000000,62\nAd C - Lookalike,35000,420,4000000,28"
}

