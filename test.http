### Gửi bulk email với AI variants (phân theo CLV tier)
# Requires: SENDGRID_API_KEY trong .env
POST {{base}}/api/commerce/personalize/send-bulk
Content-Type: application/json

{
  "customers": [
    { "email": "a@example.com", "name": "Nguyễn An", "clv_tier": "champion", "total_spent": 12000000 },
    { "email": "b@example.com", "name": "Trần Bích", "clv_tier": "loyal", "total_spent": 4500000 },
    { "email": "c@example.com", "name": "Lê Cường", "clv_tier": "potential", "total_spent": 800000 },
    { "email": "d@example.com", "name": "Phạm Dung", "clv_tier": "at_risk", "total_spent": 200000 }
  ],
  "base_message": "FuviAI vừa ra mắt tính năng mới: AI tự động tạo content cho TikTok, Shopee, Google Ads. Giúp tiết kiệm 3 giờ/ngày và tăng doanh thu.",
  "subject": "FuviAI — Tính năng mới tháng 3/2026"
}

