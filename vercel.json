{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "api/index.py" },
    { "src": "/health",        "dest": "api/index.py" },
    { "src": "/health/(.*)",   "dest": "api/index.py" },
    { "src": "/docs",          "dest": "api/index.py" },
    { "src": "/redoc",         "dest": "api/index.py" },
    { "src": "/openapi.json",  "dest": "api/index.py" },
    { "src": "/(.*)",          "dest": "frontend/$1"  }
  ]
}
